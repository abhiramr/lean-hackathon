{
  "name": "verified-eda-ui",
  "version": "1.0.0",
  "private": true,
  "description": "Verified EDA — Formally Verified Exploratory Data Analysis UI",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "server": "cd backend && python server.py",
    "start": "concurrently \"npm run server\" \"npm run dev\"",
    "electron": "concurrently \"npm run server\" \"wait-on http://localhost:5173 && electron electron/main.js\"",
    "electron:build": "vite build && electron-builder"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.12.7",
    "lucide-react": "^0.383.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "vite": "^5.3.1",
    "wait-on": "^7.2.0"
  }
}
